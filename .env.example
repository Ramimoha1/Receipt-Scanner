# =============================================================================
# Receipt Scanner AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# =============================================================================

# REQUIRED: Google Gemini API Key
# Get it from: https://aistudio.google.com/apikey
GEMINI_API_KEY=sk_your_actual_api_key_here

# REQUIRED: PostgreSQL Database Configuration
# Default: Local PostgreSQL on port 5432
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/receipt_scanner_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_postgres_password

# OPTIONAL: Other Configuration
# Spring Boot Profile (development/production)
SPRING_PROFILES_ACTIVE=default

# OPTIONAL: Gemini Model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
